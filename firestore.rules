rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // デフォルト: 全アクセス拒否
    match /{document=**} {
      allow read, write: if false;
    }

    // ユーザー自身のスケジュールのみ読み書き許可
    match /users/{userId}/schedules/{scheduleId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // 書き込み時のデータ検証
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasAll(['title', 'day', 'period', 'createdAt'])
        && request.resource.data.title is string
        && request.resource.data.title.size() >= 1
        && request.resource.data.title.size() <= 100
        && request.resource.data.day in ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday']
        && request.resource.data.period is int
        && request.resource.data.period >= 1
        && request.resource.data.period <= 12;

      allow update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['absences'])
        && request.resource.data.absences is int
        && request.resource.data.absences >= 0
        && request.resource.data.absences <= 999;

      allow delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
